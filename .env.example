# =============================================================================
# aiagent-comms 环境变量模板
# 复制为 .env 后填写真实值；.env 已加入 .gitignore，切勿提交。
# =============================================================================

# -----------------------------------------------------------------------------
# 1. 主服务
# -----------------------------------------------------------------------------
AIAGENT_HOST=127.0.0.1
AIAGENT_PORT=8766

# -----------------------------------------------------------------------------
# 2. LLM（Mavis 托管 MiniMax-M3）
# -----------------------------------------------------------------------------
# Mavis Code 会自动注入 MAVIS_ACCESS_TOKEN；普通环境需手动设置
MAVIS_ACCESS_TOKEN=your_mavis_access_token

LLM_API_BASE=https://agent.minimaxi.com/mavis/api/v1/llm/v1
LLM_API_KEY=sk-xxx
LLM_MODEL=minimax/MiniMax-M3

# -----------------------------------------------------------------------------
# 3. 数据存储（默认 SQLite，生产可切 PostgreSQL）
# -----------------------------------------------------------------------------
DATABASE_URL=sqlite:///data/orders.db
STORAGE_BACKEND=sqlite

PG_HOST=localhost
PG_PORT=5432
PG_DB=aiagent
PG_USER=aiagent
PG_PASSWORD=your_pg_password

# -----------------------------------------------------------------------------
# 4. 翻译
# -----------------------------------------------------------------------------
TRANSLATION_PROVIDER=llm
DEEPL_API_KEY=your_deepl_key

# -----------------------------------------------------------------------------
# 5. 语音 / 短信通道（默认 mock）
# -----------------------------------------------------------------------------
VOICE_MOCK=1
SMS_MOCK=1

# Twilio 真实语音
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+1234567890
TWILIO_WEBHOOK_BASE=https://your-ngrok.ngrok.io

# 阿里云 SMS 真实短信（backend/channels/sms.py 中 _aliyun_send 需补实现）
ALIYUN_ACCESS_KEY=your_aliyun_key
ALIYUN_ACCESS_SECRET=your_aliyun_secret

# -----------------------------------------------------------------------------
# 6. Celery + Redis（默认关闭）
# -----------------------------------------------------------------------------
CELERY_ENABLED=0
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# -----------------------------------------------------------------------------
# 7. 邮件 Worker（V3.1 / V4.0 邮件网关）
# -----------------------------------------------------------------------------
AIAGENT_API_BASE=http://127.0.0.1:8766

IMAP_HOST=imap.qq.com
IMAP_PORT=993
IMAP_USER=your_email@qq.com
IMAP_PASSWORD=your_imap_password

SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=your_email@qq.com
SMTP_PASSWORD=your_smtp_password
SMTP_FROM_NAME=AI 外贸代办

EMAIL_POLL_INTERVAL=30
APPROVED_SENDERS=customer1@example.com,customer2@example.com

LOG_FILE=data/email_worker.log
PID_FILE=data/email_worker.pid

# -----------------------------------------------------------------------------
# 8. 可观测性
# -----------------------------------------------------------------------------
ENABLE_OTEL=0
